    ">=2.0.0"
  ],
  "ledmatrix_version": "2.0.0",
  "requires": {
    "python": ">=3.9",
    "display_size": {
      "min_width": 64,
      "min_height": 32
    }
  },
  "config_schema": "config_schema.json",
  "assets": {
    "logos": "Uses shared LEDMatrix assets/sports/ncaa_logos directory"
  },
  "update_interval": 60,
  "default_duration": 15,
  "display_modes": [
    "ncaa_mens_recent",
    "ncaa_mens_upcoming",
    "ncaa_mens_live",
    "ncaa_womens_recent",
    "ncaa_womens_upcoming",
    "ncaa_womens_live"
  ],
  "api_requirements": [
    {
      "name": "ESPN API",
      "required": true,
